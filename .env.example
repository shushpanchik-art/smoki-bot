# --- Gemini / Google GenAI ---
# GEMINI_API_KEY нужен ТОЛЬКО если GOOGLE_GENAI_USE_VERTEXAI=false.
# В проде используется Vertex AI (креды из окружения), ключ не требуется.
GEMINI_API_KEY=
# Резервный ключ AI Studio (переключение при лимите/блоке Vertex).
GEMINI_API_KEY_FALLBACK=
GEMINI_TEXT_MODEL=
GEMINI_IMAGE_MODEL=

# --- Vertex AI (опционально, если GOOGLE_GENAI_USE_VERTEXAI=true) ---
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# --- Cloud Billing (факт расходов через BigQuery export) ---
