# В проде используется Vertex AI (креды из окружения), ключ не требуется.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=
GEMINI_IMAGE_MODEL=

# --- Vertex AI (опционально, если GOOGLE_GENAI_USE_VERTEXAI=true) ---
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# --- Хранилище ---
DB_PATH=
IMAGE_DIR=

# --- Сеть / расписание ---
WEBHOOK_PORT=
PUBLISH_HOUR=
COMMENTS_INTERVAL_HOURS=
MAX_REGEN=

# --- Окна генерации/публикации (часы, локальное время сервера) ---
